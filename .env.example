# IndraNet Environment Variables
# Copy this file to .env and fill in values. Never commit .env.

# ─── Backend Server ───────────────────────────────────────────────────────────
INDRANET_ENV=development          # development | staging | production
INDRANET_PORT=8080                # HTTP server port
INDRANET_LOG_LEVEL=debug          # debug | info | warn | error

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=indranet
POSTGRES_USER=indranet
POSTGRES_PASSWORD=changeme
# Full DSN (alternative to individual vars)
# DATABASE_URL=postgres://indranet:changeme@localhost:5432/indranet?sslmode=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── NATS ─────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY_HOURS=24

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...     # From Stripe Dashboard → API Keys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # From Stripe Dashboard → Webhooks → Signing secret
STRIPE_PLATFORM_FEE_PERCENT=20    # Platform commission percentage (host receives 100 - this)

# ─── Cloudflare R2 (file storage) ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=indranet
R2_PUBLIC_URL=

# ─── Local MinIO (dev only, mirrors R2 interface) ─────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000

# ─── Session Config ───────────────────────────────────────────────────────────
SESSION_BILLING_TICK_SECONDS=60           # How often billing engine ticks
SESSION_WARNING_MINUTES_REMAINING=5       # Warn user when this many minutes left
SESSION_MAX_DURATION_HOURS=8             # Hard cap on session length

# ─── STUN / TURN (WebRTC NAT traversal) ──────────────────────────────────────
STUN_SERVER=stun:stun.l.google.com:19302  # Free STUN for dev; use own in prod
TURN_SERVER=                              # turn:your-turn-server.com:3478
TURN_USERNAME=
TURN_PASSWORD=

# ─── Web Frontend (Next.js) ───────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000   # Used by backend for Stripe redirect URLs
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# TURN config for WebRTC peer connections (leave blank to use STUN-only)
NEXT_PUBLIC_TURN_URL=                     # e.g. turn:your-turn-server.com:3478
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# ─── Host Agent ───────────────────────────────────────────────────────────────
AGENT_BACKEND_URL=http://localhost:8080
AGENT_LOG_PATH=C:\IndraNet\logs\agent.log  # Windows path example
